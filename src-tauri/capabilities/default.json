{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "MCPM 默认权限配置",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "shell:allow-execute",
    "process:default",
    "process:allow-exit",
    "process:allow-restart",
    "autostart:default",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled",
    "dialog:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file"
  ]
}
